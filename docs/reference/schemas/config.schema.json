{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://icebox.dev/schemas/config.schema.json",
  "title": "Icebox Config",
  "type": "object",
  "required": [
    "format",
    "schemaVersion",
    "activeAgentId",
    "agents",
    "createdByVersion",
    "lastMigratedByVersion"
  ],
  "properties": {
    "format": {
      "const": "icebox.config"
    },
    "schemaVersion": {
      "type": "integer",
      "minimum": 1
    },
    "activeAgentId": {
      "type": ["string", "null"]
    },
    "agents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["agentId", "name", "did"],
        "properties": {
          "agentId": {
            "type": "string",
            "minLength": 8
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "did": {
            "type": "string",
            "minLength": 1
          },
          "identityLane": {
            "type": ["string", "null"],
            "enum": ["local-enclave", "paired-remote-signer", null]
          },
          "backendClass": {
            "type": ["string", "null"]
          },
          "deviceBindings": {
            "type": ["array", "null"],
            "items": {
              "type": "object",
              "required": ["deviceId", "backendClass"],
              "properties": {
                "deviceId": {
                  "type": "string",
                  "minLength": 1
                },
                "backendClass": {
                  "type": "string",
                  "minLength": 1
                },
                "status": {
                  "type": "string",
                  "enum": ["active", "revoked", "pending"]
                }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    },
    "createdByVersion": {
      "type": "string",
      "minLength": 1
    },
    "lastMigratedByVersion": {
      "type": ["string", "null"]
    }
  },
  "additionalProperties": true
}
